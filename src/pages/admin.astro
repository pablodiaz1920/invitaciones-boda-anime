---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Panel de Administración - Débora & Pablo">
  <main class="min-h-screen bg-stone-950 text-white py-8 px-4 md:px-6">
    <div class="max-w-5xl mx-auto">

      <!-- Header -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="font-title text-xl md:text-2xl text-amber-400">Panel de Administración</h1>
          <p class="text-xs text-stone-400 mt-1">Gestión de invitados — Débora & Pablo</p>
        </div>
        <a href="./" class="text-xs text-stone-400 hover:text-amber-400 transition">
          <i class="fa-solid fa-arrow-left mr-1"></i>Volver a la boda
        </a>
      </div>

      <!-- Login Form -->
      <div id="admin-login" class="hidden max-w-md mx-auto mt-16">
        <div class="bg-stone-900 rounded-2xl p-8 border border-stone-700 shadow-xl">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-amber-500/20 text-amber-400 rounded-full flex items-center justify-center text-2xl mx-auto mb-4">
              <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h2 class="font-title text-lg text-white">Acceso Administrativo</h2>
            <p class="text-xs text-stone-400 mt-1">Ingresa con tu email y contraseña de Supabase Auth</p>
          </div>

          <div class="space-y-4">
            <div>
              <label class="block text-[10px] uppercase font-bold text-stone-400 mb-1.5 tracking-wider">Email</label>
              <input type="email" id="admin-email" placeholder="tu@email.com" class="w-full bg-stone-800 border border-stone-600 rounded-xl px-4 py-2.5 text-sm outline-none focus:border-amber-500 text-white placeholder-stone-500 transition" />
            </div>
            <div>
              <label class="block text-[10px] uppercase font-bold text-stone-400 mb-1.5 tracking-wider">Contraseña</label>
              <input type="password" id="admin-password" placeholder="••••••••" class="w-full bg-stone-800 border border-stone-600 rounded-xl px-4 py-2.5 text-sm outline-none focus:border-amber-500 text-white placeholder-stone-500 transition" />
            </div>
            <div id="admin-login-error" class="hidden text-red-400 text-xs text-center"></div>
            <button onclick="handleAdminLogin()" class="w-full bg-amber-500 hover:bg-amber-600 text-stone-950 font-bold uppercase tracking-wider text-sm py-3 rounded-xl transition">
              <i class="fa-solid fa-key mr-2"></i>Ingresar
            </button>
          </div>
        </div>
      </div>

      <!-- Dashboard -->
      <div id="admin-dashboard" class="hidden space-y-6">
        <!-- Dashboard Header -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <div id="admin-stats"></div>
          <button onclick="handleAdminLogout()" class="text-xs text-stone-400 hover:text-red-400 transition">
            <i class="fa-solid fa-right-from-bracket mr-1"></i>Cerrar sesión
          </button>
        </div>

        <!-- Add Guest Form -->
        <div class="bg-stone-900 rounded-2xl p-5 md:p-6 border border-stone-700">
          <h3 class="font-title text-sm text-amber-400 mb-4 flex items-center space-x-2">
            <i class="fa-solid fa-user-plus"></i>
            <span>Añadir Nuevo Invitado</span>
          </h3>
          <div class="flex flex-col sm:flex-row gap-3">
            <input type="text" id="new-guest-name" placeholder="Nombre del invitado" class="flex-1 bg-stone-800 border border-stone-600 rounded-xl px-4 py-2.5 text-sm outline-none focus:border-amber-500 text-white placeholder-stone-500 transition" />
            <select id="new-guest-passes" class="sm:w-32 bg-stone-800 border border-stone-600 rounded-xl px-4 py-2.5 text-sm outline-none focus:border-amber-500 text-white transition">
              <option value="1">1 Pase</option>
              <option value="2" selected>2 Pases</option>
              <option value="3">3 Pases</option>
              <option value="4">4 Pases</option>
              <option value="5">5 Pases</option>
            </select>
            <button onclick="addGuest()" class="bg-amber-500 hover:bg-amber-600 text-stone-950 font-bold uppercase text-xs px-6 py-2.5 rounded-xl transition whitespace-nowrap">
              <i class="fa-solid fa-plus mr-1"></i>Añadir
            </button>
          </div>
          <div id="add-guest-error" class="hidden text-red-400 text-xs mt-2"></div>
        </div>

        <!-- Guests Table -->
        <div class="bg-stone-900 rounded-2xl border border-stone-700 overflow-hidden">
          <div class="p-4 md:p-5 border-b border-stone-700">
            <h3 class="font-title text-sm text-amber-400 flex items-center space-x-2">
              <i class="fa-solid fa-users"></i>
              <span>Lista de Invitados</span>
            </h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="text-[10px] uppercase tracking-wider text-stone-400 border-b border-stone-800">
                  <th class="py-3 px-3 font-semibold">Nombre</th>
                  <th class="py-3 px-3 font-semibold text-center">Pases</th>
                  <th class="py-3 px-3 font-semibold text-center">Estado</th>
                  <th class="py-3 px-3 font-semibold hidden md:table-cell">Alimentación</th>
                  <th class="py-3 px-3 font-semibold hidden md:table-cell">Canción</th>
                  <th class="py-3 px-3 font-semibold text-center">Acciones</th>
                </tr>
              </thead>
              <tbody id="guests-table-body">
                <tr><td colspan="6" class="text-center py-8 text-stone-400">Iniciando sesión...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </main>
</Layout>

<script>
  import '../scripts/admin.js';
</script>
