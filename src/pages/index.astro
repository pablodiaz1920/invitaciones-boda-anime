---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PersonalizedBanner from '../components/PersonalizedBanner.astro';
import Hero from '../components/Hero.astro';
import Countdown from '../components/Countdown.astro';
import History from '../components/History.astro';
import Details from '../components/Details.astro';
import Itinerary from '../components/Itinerary.astro';
import Gifts from '../components/Gifts.astro';
import RSVP from '../components/RSVP.astro';
import Footer from '../components/Footer.astro';

const url = new URL(Astro.request.url);
const guest = url.searchParams.get('g');
const passes = url.searchParams.get('p');
---

<Layout>
  <Navbar />
  <PersonalizedBanner guest={guest} passes={passes} />
  <Hero />
  <Countdown />
  <History />
  <Details />
  <Itinerary />
  <Gifts />
  <RSVP guest={guest} passes={passes} />
  <Footer />
</Layout>
