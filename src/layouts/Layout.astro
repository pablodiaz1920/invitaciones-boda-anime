---
export interface Props {
  title?: string;
}

const { title = "¡La Gran Alianza! Boda de Débora & Pablo" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Montserrat:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="bg-wedding-bg text-wedding-dark min-h-screen font-sans overflow-x-hidden">
    <canvas id="sakura-canvas" class="fixed top-0 left-0 w-full h-full pointer-events-none z-50"></canvas>

    <div class="fixed bottom-6 right-6 z-50 flex flex-col space-y-2">
      <button id="music-btn" class="w-14 h-14 bg-white text-rose-600 rounded-full flex items-center justify-center shadow-2xl border-2 border-rose-500 hover:scale-110 active:scale-95 transition-transform duration-200">
        <i id="music-icon" class="fas fa-music text-xl"></i>
      </button>
      <audio id="bg-music" loop>
        <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg" />
      </audio>
    </div>

    <div id="toast" class="fixed top-24 right-6 bg-wedding-rose text-white text-xxs md:text-xs uppercase font-bold tracking-wider px-5 py-2.5 md:px-6 md:py-3 rounded-xl shadow-2xl border border-rose-700 translate-x-80 opacity-0 transition-all duration-300 z-50">
      ¡Copiado al portapapeles!
    </div>

    <slot />

    <script>
      import '../scripts/sakura.js';
      import '../scripts/main.js';
    </script>
  </body>
</html>
