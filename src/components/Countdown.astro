<section class="anim-fade-in-up bg-gradient-to-r from-red-950 via-rose-950 to-stone-950 text-white py-10 px-4 md:px-6 shadow-xl relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-amber-500/10 via-transparent to-transparent"></div>
  <div class="max-w-4xl mx-auto text-center relative z-10">
    <h3 class="font-title text-pirate-gold text-xs md:text-base tracking-widest uppercase mb-6">Comienza la cuenta regresiva para zarpar</h3>

    <div class="grid grid-cols-4 gap-2 md:gap-6 max-w-2xl mx-auto">
      <div class="bg-white/10 backdrop-blur-md rounded-xl md:rounded-2xl p-2.5 md:p-6 border border-white/10">
        <span id="days" class="block text-xl sm:text-3xl md:text-5xl font-title font-bold text-pirate-gold">00</span>
        <span class="text-[9px] md:text-xs uppercase tracking-widest text-stone-300 font-semibold mt-1 block">Días</span>
      </div>
      <div class="bg-white/10 backdrop-blur-md rounded-xl md:rounded-2xl p-2.5 md:p-6 border border-white/10">
        <span id="hours" class="block text-xl sm:text-3xl md:text-5xl font-title font-bold text-pirate-gold">00</span>
        <span class="text-[9px] md:text-xs uppercase tracking-widest text-stone-300 font-semibold mt-1 block">Horas</span>
      </div>
      <div class="bg-white/10 backdrop-blur-md rounded-xl md:rounded-2xl p-2.5 md:p-6 border border-white/10">
        <span id="minutes" class="block text-xl sm:text-3xl md:text-5xl font-title font-bold text-pirate-gold">00</span>
        <span class="text-[9px] md:text-xs uppercase tracking-widest text-stone-300 font-semibold mt-1 block">Mins</span>
      </div>
      <div class="bg-white/10 backdrop-blur-md rounded-xl md:rounded-2xl p-2.5 md:p-6 border border-white/10">
        <span id="seconds" class="block text-xl sm:text-3xl md:text-5xl font-title font-bold text-pirate-gold">00</span>
        <span class="text-[9px] md:text-xs uppercase tracking-widest text-stone-300 font-semibold mt-1 block">Segs</span>
      </div>
    </div>

    <p class="mt-8 italic font-serif-elegant text-stone-300 text-xs md:text-base">"¡Incluso si la tormenta es grande, navegaremos con la fuerza de un Hokage!"</p>
  </div>
</section>
