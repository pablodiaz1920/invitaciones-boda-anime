<section id="rsvp" class="py-12 md:py-20 px-4 md:px-6 max-w-4xl mx-auto">
  <div class="anim-scale-in anime-border bg-ninja-cream rounded-3xl p-5 md:p-12 shadow-2xl relative">
    <div class="text-center space-y-4 mb-8">
      <span class="text-[10px] md:text-xs uppercase font-bold tracking-widest text-wedding-rose bg-rose-100 px-4 py-1.5 rounded-full inline-block">Misión de Rango S</span>
      <h2 class="font-title text-2xl md:text-3xl text-stone-950">Registro de Asistencia</h2>
      <div class="h-1 w-20 bg-wedding-gold mx-auto rounded-full"></div>
      <p class="text-stone-600 text-xs md:text-sm font-serif-elegant italic">Por favor, confirma tu asistencia antes del 15 de Diciembre de 2026 para asegurar tu asiento en la tripulación.</p>
    </div>

    <div id="rsvp-confirmed" class="hidden text-center space-y-6 py-4">
      <div class="w-16 h-16 md:w-20 md:h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center text-3xl md:text-4xl shadow-md mx-auto">
        <i class="fa-solid fa-circle-check"></i>
      </div>
      <h3 class="font-title text-xl md:text-2xl text-stone-950">¡Ya confirmaste tu asistencia!</h3>
      <div id="rsvp-confirmed-details" class="bg-white/80 rounded-2xl p-6 max-w-lg mx-auto text-left space-y-2 text-sm md:text-base text-stone-700"></div>
      <p class="text-stone-500 text-xs italic">Si necesitas cambiar algo, escríbenos directamente. ¡Nos vemos en la Gran Ruta!</p>
    </div>

    <form id="rsvp-form" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs uppercase font-bold text-wedding-rose tracking-wider mb-2">Nombre Completo</label>
          <input type="text" id="rsvp-name" required placeholder="Escribe tu nombre y apellido" class="w-full px-4 py-3 rounded-xl border border-rose-200 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none text-sm transition bg-white/70" />
        </div>
        <div>
          <label class="block text-xs uppercase font-bold text-wedding-rose tracking-wider mb-2">¿Asistirás a la Alianza?</label>
          <select id="rsvp-status" required class="w-full px-4 py-3 rounded-xl border border-rose-200 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none text-sm transition bg-white/70">
            <option value="">Selecciona una opción</option>
            <option value="yes">¡Sí, juro mi camino ninja y zarparé con ustedes!</option>
            <option value="no">No podré asistir, me quedaré defendiendo la aldea</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs uppercase font-bold text-wedding-rose tracking-wider mb-2">Número de Invitados / Pases</label>
          <select id="rsvp-guests" class="w-full px-4 py-3 rounded-xl border border-rose-200 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none text-sm transition bg-white/70">
            <option value="1">Solo yo (1 Persona)</option>
            <option value="2">Yo + 1 Acompañante (2 Personas)</option>
            <option value="3">Grupo / Familia (3 Personas)</option>
            <option value="4">Grupo / Familia (4 Personas)</option>
            <option value="5">Grupo / Familia (5 Personas)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs uppercase font-bold text-wedding-rose tracking-wider mb-2">Restricciones Alimenticias (Opcional)</label>
          <input type="text" id="rsvp-food" placeholder="Alergias, vegano, vegetariano, etc." class="w-full px-4 py-3 rounded-xl border border-rose-200 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none text-sm transition bg-white/70" />
        </div>
      </div>

      <div>
        <label class="block text-xs uppercase font-bold text-wedding-rose tracking-wider mb-2">Canción indispensable para la fiesta (Opcional)</label>
        <input type="text" id="rsvp-song" placeholder="Canción - Artista (¡Se vale pedir openings de anime!)" class="w-full px-4 py-3 rounded-xl border border-rose-200 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none text-sm transition bg-white/70" />
      </div>

      <div>
        <label class="block text-xs uppercase font-bold text-wedding-rose tracking-wider mb-2">Mensaje especial para Debora & Pablo</label>
        <textarea id="rsvp-message" rows="4" placeholder="Déjanos un consejo de matrimonio o tus mejores deseos al estilo pirata/shinobi..." class="w-full px-4 py-3 rounded-xl border border-rose-200 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none text-sm transition bg-white/70"></textarea>
      </div>

      <div class="text-center pt-4">
        <button type="submit" class="bg-gradient-to-r from-pirate-red to-ninja-red text-white hover:scale-105 active:scale-95 transition shadow-lg px-8 py-4 rounded-full font-bold uppercase tracking-wider text-xs md:text-sm flex items-center justify-center space-x-2 mx-auto w-full md:w-auto">
          <i class="fa-solid fa-paper-plane"></i>
          <span>Firmar el Registro de Alianza</span>
        </button>
      </div>
    </form>

    <div id="rsvp-success-modal" class="hidden absolute inset-0 bg-white/95 rounded-3xl flex flex-col items-center justify-center p-6 md:p-8 text-center space-y-6 z-20">
      <div class="w-16 h-16 md:w-20 md:h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center text-3xl md:text-4xl shadow-md">
        <i class="fa-solid fa-circle-check"></i>
      </div>
      <h3 class="font-title text-xl md:text-2xl text-stone-950">¡Misión Registrada Exitosamente!</h3>
      <p class="text-stone-600 text-xs md:text-sm max-w-md mx-auto">
        Tu pergamino de confirmación ha sido recibido por el equipo de Debora y Pablo. ¡La alianza se fortalece con tu presencia!
      </p>
      <button onclick="reiniciarFormulario()" class="px-6 py-2 bg-rose-100 text-wedding-rose hover:bg-rose-200 font-bold uppercase text-xs tracking-wider rounded-full transition">
        Volver al formulario
      </button>
    </div>
  </div>
</section>
